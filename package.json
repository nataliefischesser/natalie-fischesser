{
  "name": "natalie-fischesser",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "generate-ico": "pnpx icon-gen@latest -i ./public/favicon.svg -o ./public --ico --ico-name favicon --ico-sizes 16,32,48",
    "generate-png": "pnpx svg2png@latest ./public/favicon.svg -o ./public/favicon.png -w 512 -h 512",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix",
    "postinstall": "nuxt prepare",
    "preview": "nuxt preview",
    "test": "pnpm run lint && pnpm run type-check",
    "type-check": "nuxt typecheck"
  },
  "devDependencies": {
    "@csstools/postcss-oklab-function": "^5.0.3",
    "@danielwaltz/eslint-config": "^3.4.0",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.79",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@types/node": "~24.10.15",
    "@unocss/eslint-plugin": "^66.6.8",
    "@unocss/nuxt": "^66.6.8",
    "@vueuse/motion": "^3.0.3",
    "@vueuse/nuxt": "^14.2.1",
    "eslint": "^10.2.1",
    "nuxt": "^4.4.2",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "unocss": "^66.6.8",
    "vite": "^7.3.2",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "vue-tsc": "^3.2.7"
  }
}
